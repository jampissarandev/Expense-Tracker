    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
