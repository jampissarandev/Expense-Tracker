# Project-specific
# =============================================================
# Local env / secrets — never commit
.env
.env.example.bak
secrets/
*.pem
*.key
*.p12
*.pfx

# Database dumps
*.sql.gz
*.dump

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
blob-report/
playwright/.cache/
# Frontend-nested Playwright outputs (root patterns above don't match)
/frontend/test-results/
/frontend/playwright-report/
/frontend/playwright/.cache/

# Lighthouse CI
/frontend/.lighthouseci/
.lighthouseci/

# Lighthouse seed credentials (produced by scripts/lh-seed.py; contains
# email + password + JWT access token — never commit, regenerate locally).
/lh-user.txt
lh-user.txt

# graphify — keep the curated outputs (GRAPH_REPORT.md, graph.html, graph.json,
# manifest.json, .graphify_labels.json, cache/stat-index.json) and ignore
# everything else the pipeline regenerates: dated snapshot backups, the
# working-state dotfiles, and the per-file AST/semantic cache.
graphify-out/.graphify_*.json
!graphify-out/.graphify_labels.json
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_detect.json
graphify-out/.graphify_ast.json
graphify-out/.graphify_semantic*.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_uncached.txt
graphify-out/.graphify_cached.json
graphify-out/.graphify_chunk_*.json
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
graphify-out/cache/

# Coverage artifacts
/coverage/
/.nyc_output/

# ── JWT dev secret rule (R-3) ──────────────────────────────────
# The dev secret in appsettings.Development.json is intentional for
# local dev only.  Production must override via env var Jwt__SecretKey
# (see ADR-0006).

# ── Copilot agent local memory ────────────────────────────────
# Per-session notes written by the GitHub Copilot agent into
# .github/copilot-memory/. Not part of the project — never commit.
.github/copilot-memory/
